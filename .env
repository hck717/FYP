# ========================================
# Airflow Core Configuration
# ========================================
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__ENABLE_XCOM_PICKLING=true
AIRFLOW__WEBSERVER__SECRET_KEY=your-super-secret-key-change-this-in-prod
AIRFLOW_UID=50000
AIRFLOW__WEBSERVER__WORKERS=2
AIRFLOW__WEBSERVER__WEB_SERVER_MASTER_TIMEOUT=300
AIRFLOW__WEBSERVER__WEB_SERVER_WORKER_TIMEOUT=300
AIRFLOW__CORE__PARALLELISM=4
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=4
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=1
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin

# ========================================
# Databases
# ========================================
# PostgreSQL (Airflow metadata)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow



# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=SecureNeo4jPass2025!
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_HTTP_PORT=7474

# ========================================
# Financial Data APIs (Get your free keys)
# ========================================
FMP_API_KEY=6kqjitcYPxyr60Xy1Jfem92Q1z9LfCHM
EODHD_API_KEY=6957671cac2858.27368157
PERPLEXITY_API_KEY=your-perplexity-api-key-here


# ========================================
# LLM + Embedding
# ========================================
# Ollama is kept for embeddings only (nomic-embed-text:v1.5).
# LLM generation uses the DeepSeek API (see DEEPSEEK_API_KEY below).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
LLM_MODEL_BUSINESS_ANALYST=deepseek-reasoner
LLM_MODEL_QUANTITATIVE=deepseek-chat
LLM_MODEL_QUANT_FUNDAMENTAL=deepseek-chat
LLM_MODEL_FINANCIAL_MODELING=deepseek-reasoner
EMBEDDING_MODEL=nomic-embed-text:v1.5
EMBEDDING_DIMENSION=768
QDRANT_EMBEDDING_MODEL=nomic-embed-text
QDRANT_EMBEDDING_DIMENSION=768
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ========================================
# Agent Parameters (Tune for your FYP)
# ========================================
BUSINESS_ANALYST_MAX_CHUNKS=50
BUSINESS_ANALYST_CHUNK_SIZE=1000
BUSINESS_ANALYST_OVERLAP=200
BUSINESS_ANALYST_MAX_TOKENS=32000
QUANT_AGENT_SQL_TIMEOUT=30
QUANT_AGENT_VERIFICATION_THRESHOLD=0.8
FIN_MODEL_DCF_DISCOUNT_RATE=0.08
FIN_MODEL_TERMINAL_GROWTH_RATE=0.025
CRAG_CORRECT_THRESHOLD=0.7
CRAG_AMBIGUOUS_THRESHOLD=0.5
RAG_TOP_K=8
RAG_SCORE_THRESHOLD=0.6

# ========================================
# Data Ingestion
# ========================================
TRACKED_TICKERS=AAPL,TSLA,NVDA,MSFT,GOOGL
FMP_RATE_LIMIT=300
EODHD_RATE_LIMIT=1000
DATA_RETENTION_DAYS=730

# ========================================
# Logging (Hong Kong timezone)
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s %(levelname)s %(name)s %(message)s
TZ=Asia/Hong_Kong

# ========================================
# DeepSeek API — Business Analyst agent LLM generation
# ========================================
DEEPSEEK_API_KEY=sk-9fe1b0635ca341f3bccbe222132e3461
BUSINESS_ANALYST_LLM_PROVIDER=deepseek